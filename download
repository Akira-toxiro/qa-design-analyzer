<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QA Design — Score</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@400;500&display=swap');

  :root {
    --bg: #F7F6F2;
    --surface: #FFFFFF;
    --surface2: #F0EEE8;
    --border: #E2DDD6;
    --border2: #D0C9C0;
    --text: #1A1916;
    --text2: #6B6660;
    --text3: #9E9891;
    --green: #1C6B47;
    --green-bg: #E8F5EE;
    --yellow: #8A6300;
    --yellow-bg: #FFF8E6;
    --red: #B52B2B;
    --red-bg: #FDEAEA;
    --score-0: #E24B4A;
    --score-1: #EF9F27;
    --score-2: #1D9E75;
    --font: 'DM Sans', sans-serif;
    --mono: 'DM Mono', monospace;
    --radius: 10px;
    --radius-sm: 6px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: var(--font); background: var(--bg); color: var(--text); min-height: 100vh; font-size: 14px; line-height: 1.5; }

  .header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 20px 32px; display: flex; align-items: center; justify-content: space-between; }
  .header-title { font-size: 18px; font-weight: 600; letter-spacing: -0.3px; }
  .header-sub { font-size: 12px; color: var(--text3); margin-top: 2px; }

  .main { max-width: 1140px; margin: 0 auto; padding: 28px 24px; }

  .upload-zone { background: var(--surface); border: 2px dashed var(--border2); border-radius: var(--radius); padding: 40px 24px; text-align: center; cursor: pointer; transition: border-color 0.2s, background 0.2s; position: relative; margin-bottom: 24px; }
  .upload-zone:hover, .upload-zone.dragover { border-color: var(--text); background: var(--surface2); }
  .upload-zone input[type=file] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
  .upload-icon { width: 40px; height: 40px; margin: 0 auto 12px; opacity: 0.4; }
  .upload-title { font-size: 15px; font-weight: 500; margin-bottom: 4px; }
  .upload-sub { font-size: 12px; color: var(--text3); }

  .preview-bar { display: none; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 18px; align-items: center; gap: 14px; margin-bottom: 24px; }
  .preview-bar.visible { display: flex; }
  .preview-thumb { width: 52px; height: 52px; border-radius: var(--radius-sm); object-fit: cover; border: 1px solid var(--border); }
  .preview-info { flex: 1; }
  .preview-name { font-weight: 500; font-size: 13px; }
  .preview-size { font-size: 11px; color: var(--text3); margin-top: 2px; }
  .btn-remove { background: none; border: none; cursor: pointer; color: var(--text3); padding: 4px; }
  .btn-remove:hover { color: var(--red); }

  .btn-analyze { display: block; width: 100%; padding: 14px; background: var(--text); color: #fff; border: none; border-radius: var(--radius); font-family: var(--font); font-size: 14px; font-weight: 500; cursor: pointer; letter-spacing: 0.1px; transition: opacity 0.15s, transform 0.1s; margin-bottom: 32px; }
  .btn-analyze:hover { opacity: 0.85; }
  .btn-analyze:active { transform: scale(0.99); }
  .btn-analyze:disabled { opacity: 0.4; cursor: not-allowed; }

  .loading { display: none; text-align: center; padding: 48px; background: var(--surface); border-radius: var(--radius); margin-bottom: 24px; }
  .loading.visible { display: block; }
  .spinner { width: 32px; height: 32px; border: 2px solid var(--border); border-top-color: var(--text); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 16px; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading-text { font-size: 13px; color: var(--text2); }
  .loading-step { font-size: 11px; color: var(--text3); margin-top: 6px; font-family: var(--mono); }

  .results { display: none; }
  .results.visible { display: block; }

  .score-hero { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px; display: flex; gap: 28px; align-items: center; margin-bottom: 20px; }
  .score-number { font-size: 64px; font-weight: 600; letter-spacing: -3px; line-height: 1; font-variant-numeric: tabular-nums; }
  .score-pct { font-size: 28px; font-weight: 300; }
  .score-meta { flex: 1; }
  .score-label { display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; border-radius: 100px; font-size: 12px; font-weight: 600; letter-spacing: 0.3px; margin-bottom: 8px; }
  .score-detail { font-size: 12px; color: var(--text3); }
  .score-action { font-size: 13px; color: var(--text2); margin-top: 4px; padding: 10px 14px; border-radius: var(--radius-sm); border-left: 3px solid; }

  .cut-alert { display: none; background: var(--red-bg); border: 1px solid #f7c1c1; border-radius: var(--radius); padding: 16px 20px; margin-bottom: 20px; }
  .cut-alert.visible { display: block; }
  .cut-alert-title { font-size: 13px; font-weight: 600; color: var(--red); margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }
  .cut-item { font-size: 12px; color: var(--red); padding: 3px 0; display: flex; align-items: flex-start; gap: 6px; }
  .cut-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--red); margin-top: 5px; flex-shrink: 0; }

  .blocks-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 20px; }
  @media (max-width: 700px) { .blocks-grid { grid-template-columns: 1fr; } }

  .block-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; }
  .block-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 14px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
  .block-title { font-size: 13px; font-weight: 600; }
  .block-score { font-size: 13px; font-weight: 600; font-family: var(--mono); }
  .criterion-row { display: flex; align-items: center; gap: 10px; padding: 6px 0; border-bottom: 1px solid var(--bg); }
  .criterion-row:last-child { border-bottom: none; }
  .criterion-name { flex: 1; font-size: 12px; color: var(--text2); }
  .score-pills { display: flex; gap: 4px; }
  .score-pill { width: 28px; height: 22px; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; border: 1px solid transparent; }
  .pill-0 { background: #FFF0F0; color: #C0392B; border-color: #f7c1c1; }
  .pill-0.active { background: var(--score-0); color: #fff; border-color: var(--score-0); }
  .pill-1 { background: #FFF8E6; color: #8A6300; border-color: #FAC775; }
  .pill-1.active { background: var(--score-1); color: #fff; border-color: var(--score-1); }
  .pill-2 { background: #E8F5EE; color: #0F6E56; border-color: #9FE1CB; }
  .pill-2.active { background: var(--score-2); color: #fff; border-color: var(--score-2); }

  .block-footer { margin-top: 12px; padding-top: 10px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
  .block-total-label { font-size: 11px; color: var(--text3); }
  .block-pct { font-size: 11px; padding: 2px 8px; border-radius: 100px; font-weight: 500; }

  .feedback-panel { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; margin-bottom: 20px; }
  .feedback-title { font-size: 13px; font-weight: 600; margin-bottom: 14px; }
  .feedback-item { padding: 10px 14px; border-radius: var(--radius-sm); margin-bottom: 8px; font-size: 12px; border-left: 3px solid; }
  .feedback-item:last-child { margin-bottom: 0; }
  .feedback-item.critical { background: var(--red-bg); border-color: var(--score-0); color: var(--red); }
  .feedback-item.warning { background: var(--yellow-bg); border-color: var(--score-1); color: var(--yellow); }
  .feedback-item.ok { background: var(--green-bg); border-color: var(--score-2); color: var(--green); }
  .feedback-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.5px; opacity: 0.7; display: block; margin-bottom: 3px; }

  .scale-row { display: grid; grid-template-columns: 90px 1fr 1fr; gap: 8px; margin-bottom: 8px; font-size: 12px; }
  .scale-range { font-family: var(--mono); font-weight: 500; padding: 8px 12px; border-radius: var(--radius-sm); text-align: center; }
  .scale-label { padding: 8px 0; color: var(--text); font-weight: 500; display: flex; align-items: center; }
  .scale-action { padding: 8px 0; color: var(--text2); display: flex; align-items: center; }

  .info-panel { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; }
  .info-title { font-size: 13px; font-weight: 600; margin-bottom: 16px; }
  .bar-track { background: var(--surface2); border-radius: 100px; height: 6px; overflow: hidden; margin-top: 6px; }
  .bar-fill { height: 100%; border-radius: 100px; transition: width 1s cubic-bezier(0.4,0,0.2,1); }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 700px) { .two-col { grid-template-columns: 1fr; } }
  .new-analysis-btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; border: 1px solid var(--border2); border-radius: var(--radius-sm); background: var(--surface); font-family: var(--font); font-size: 12px; cursor: pointer; color: var(--text2); transition: all 0.15s; margin-bottom: 24px; }
  .new-analysis-btn:hover { background: var(--surface2); color: var(--text); }
  .hidden { display: none !important; }
</style>
</head>
<body>

<div class="header">
  <div>
    <div class="header-title">QA Design — Score</div>
    <div class="header-sub">Sistema de avaliação de qualidade de peças de design</div>
  </div>
</div>

<div class="main">
  <div id="uploadSection">
    <div class="upload-zone" id="dropZone">
      <input type="file" id="fileInput" accept="image/*" />
      <svg class="upload-icon" viewBox="0 0 40 40" fill="none">
        <rect width="40" height="40" rx="8" fill="#E2DDD6"/>
        <path d="M20 26V14M20 14L15 19M20 14L25 19" stroke="#6B6660" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M12 28h16" stroke="#6B6660" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <div class="upload-title">Soltar arte aqui ou clique para selecionar</div>
      <div class="upload-sub">PNG, JPG, WEBP • Máximo 10MB</div>
    </div>
    <div class="preview-bar" id="previewBar">
      <img class="preview-thumb" id="previewThumb" src="" alt="">
      <div class="preview-info">
        <div class="preview-name" id="previewName"></div>
        <div class="preview-size" id="previewSize"></div>
      </div>
      <button class="btn-remove" id="btnRemove">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>
    <button class="btn-analyze" id="btnAnalyze" disabled>Analisar com IA</button>
  </div>

  <div class="loading" id="loadingSection">
    <div class="spinner"></div>
    <div class="loading-text">Analisando sua arte...</div>
    <div class="loading-step" id="loadingStep">Processando imagem</div>
  </div>

  <div class="results" id="resultsSection">
    <button class="new-analysis-btn" id="btnNewAnalysis">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M1 6a5 5 0 1 0 5-5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><path d="M1 2v4h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Nova análise
    </button>
    <div class="score-hero">
      <div><div class="score-number" id="heroScore">—</div></div>
      <div class="score-meta">
        <div class="score-label" id="scoreLabel"></div>
        <div class="score-detail" id="scoreDetail"></div>
        <div class="score-action" id="scoreAction"></div>
      </div>
    </div>
    <div class="cut-alert" id="cutAlert">
      <div class="cut-alert-title">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2L12.5 12H1.5L7 2Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><path d="M7 6v3M7 10.5v.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        Regras de corte detectadas — a peça não pode ser aprovada
      </div>
      <div id="cutItems"></div>
    </div>
    <div class="blocks-grid" id="blocksGrid"></div>
    <div class="two-col">
      <div class="feedback-panel">
        <div class="feedback-title">Feedback por bloco</div>
        <div id="feedbackItems"></div>
      </div>
      <div class="info-panel">
        <div class="info-title">Cálculo de pontuação</div>
        <div class="scale-row"><div class="scale-range" style="background:#E8F5EE;color:#1C6B47">90–100</div><div class="scale-label">Excelente</div><div class="scale-action">Pode subir</div></div>
        <div class="scale-row"><div class="scale-range" style="background:#EBF3FB;color:#185FA5">75–89</div><div class="scale-label">Bom</div><div class="scale-action">Ajustes finos</div></div>
        <div class="scale-row"><div class="scale-range" style="background:#FFF8E6;color:#8A6300">60–74</div><div class="scale-label">Médio</div><div class="scale-action">Revisar</div></div>
        <div class="scale-row"><div class="scale-range" style="background:#FDEAEA;color:#B52B2B">0–59</div><div class="scale-label">Crítico</div><div class="scale-action">Refazer</div></div>
        <div style="margin-top:16px;padding-top:12px;border-top:1px solid var(--border)">
          <div style="font-size:11px;color:var(--text3);margin-bottom:6px;">Pontuação por bloco</div>
          <div id="blockBars"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const CRITERIA = [
  { id: 'tipografia', title: 'Texto e Tipografia', maxPts: 12,
    criteria: [{ id: 'ortografia', name: 'Ortografia e gramática' },{ id: 'espacamento_pontuacao', name: 'Espaçamento e pontuação' },{ id: 'hierarquia_tipografica', name: 'Hierarquia tipográfica' },{ id: 'legibilidade', name: 'Legibilidade' },{ id: 'quebras_linha', name: 'Quebras de linha' },{ id: 'consistencia_estilos', name: 'Consistência de estilos' }]},
  { id: 'grid', title: 'Layout e Espaçamento', maxPts: 8,
    criteria: [{ id: 'alinhamento', name: 'Alinhamento consistente' },{ id: 'espacamento_consistente', name: 'Espaçamento consistente' },{ id: 'margens', name: 'Margens e respiro' },{ id: 'proporcao', name: 'Proporção visual equilibrada' }]},
  { id: 'hierarquia', title: 'Hierarquia e Leitura', maxPts: 8,
    criteria: [{ id: 'ponto_focal', name: 'Ponto focal' },{ id: 'ordem_leitura', name: 'Ordem de leitura natural' },{ id: 'cta', name: 'Clareza do CTA (se houver)' },{ id: 'escaneabilidade', name: 'Escaneabilidade' }]},
  { id: 'cores', title: 'Cores e Contraste', maxPts: 6,
    criteria: [{ id: 'contraste', name: 'Contraste de leitura' },{ id: 'uso_cores', name: 'Uso consistente de cores' },{ id: 'fundo', name: 'Fundo não compete com conteúdo' }]},
  { id: 'imagens', title: 'Imagens e Elementos', maxPts: 8,
    criteria: [{ id: 'qualidade_imagem', name: 'Qualidade da imagem' },{ id: 'consistencia_visual', name: 'Consistência visual' },{ id: 'recorte', name: 'Recorte bem feito (se houver)' },{ id: 'icones', name: 'Ícones padronizados (se houver)' }]},
  { id: 'marca', title: 'Consistência de Marca', maxPts: 6,
    criteria: [{ id: 'uso_marca', name: 'Uso correto da marca' },{ id: 'unidade_visual', name: 'Unidade visual' },{ id: 'padroes', name: 'Padrões respeitados' }]},
  { id: 'tecnico', title: 'Técnico', maxPts: 4,
    criteria: [{ id: 'dimensoes', name: 'Dimensões corretas' },{ id: 'nitidez', name: 'Nitidez e exportação' }]},
];
const TOTAL_PTS = CRITERIA.reduce((s, b) => s + b.maxPts, 0);
let imageBase64 = null, imageMime = null;

const dropZone = document.getElementById('dropZone');
const fileInput = document.getElementById('fileInput');
const previewBar = document.getElementById('previewBar');
const previewThumb = document.getElementById('previewThumb');
const previewName = document.getElementById('previewName');
const previewSize = document.getElementById('previewSize');
const btnAnalyze = document.getElementById('btnAnalyze');

dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('dragover'); handleFile(e.dataTransfer.files[0]); });
fileInput.addEventListener('change', () => handleFile(fileInput.files[0]));
document.getElementById('btnRemove').addEventListener('click', resetUpload);
document.getElementById('btnNewAnalysis').addEventListener('click', resetAll);
btnAnalyze.addEventListener('click', runAnalysis);

function handleFile(file) {
  if (!file) return;
  if (file.size > 10 * 1024 * 1024) { alert('Arquivo muito grande. Máximo 10MB.'); return; }
  const reader = new FileReader();
  reader.onload = e => {
    const dataUrl = e.target.result;
    imageBase64 = dataUrl.split(',')[1];
    imageMime = file.type || 'image/png';
    previewThumb.src = dataUrl;
    previewName.textContent = file.name;
    previewSize.textContent = (file.size / 1024).toFixed(1) + ' KB';
    previewBar.classList.add('visible');
    btnAnalyze.disabled = false;
  };
  reader.readAsDataURL(file);
}

function resetUpload() {
  imageBase64 = null; imageMime = null; fileInput.value = '';
  previewBar.classList.remove('visible'); btnAnalyze.disabled = true;
}
function resetAll() {
  resetUpload();
  document.getElementById('resultsSection').classList.remove('visible');
  document.getElementById('uploadSection').classList.remove('hidden');
}

const STEPS = ['Processando imagem...','Identificando elementos visuais...','Verificando tipografia e grid...','Analisando cores e contraste...','Checando hierarquia e leitura...','Calculando score final...'];
let stepInterval;
function startLoadingSteps() {
  let i = 0; document.getElementById('loadingStep').textContent = STEPS[0];
  stepInterval = setInterval(() => { i = (i+1) % STEPS.length; document.getElementById('loadingStep').textContent = STEPS[i]; }, 1800);
}

async function runAnalysis() {
  if (!imageBase64) return;
  document.getElementById('uploadSection').classList.add('hidden');
  document.getElementById('loadingSection').classList.add('visible');
  startLoadingSteps();
  try {
    const resp = await fetch('/api/analyze', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ imageBase64, imageMime })
    });
    clearInterval(stepInterval);
    if (!resp.ok) { const e = await resp.json(); throw new Error(e.error || 'Erro no servidor'); }
    const result = await resp.json();
    renderResults(result);
  } catch (err) {
    clearInterval(stepInterval);
    document.getElementById('loadingSection').classList.remove('visible');
    document.getElementById('uploadSection').classList.remove('hidden');
    alert('Erro: ' + err.message + '\n\nVerifique se o servidor está rodando (npm start)');
  }
}

function renderResults(result) {
  document.getElementById('loadingSection').classList.remove('visible');
  document.getElementById('resultsSection').classList.add('visible');
  let totalPts = 0;
  CRITERIA.forEach(b => { const bs = result.scores[b.id]||{}; b.criteria.forEach(c => { totalPts += (bs[c.id]||0); }); });
  const pct = Math.round((totalPts / TOTAL_PTS) * 100);
  const heroScore = document.getElementById('heroScore');
  heroScore.innerHTML = pct + '<span class="score-pct">%</span>';
  document.getElementById('scoreDetail').textContent = `Pontos: ${totalPts} de ${TOTAL_PTS}`;
  const scoreLabel = document.getElementById('scoreLabel');
  const scoreAction = document.getElementById('scoreAction');
  if (pct >= 90) { heroScore.style.color='#1C6B47'; scoreLabel.style.cssText='background:#E8F5EE;color:#1C6B47'; scoreLabel.textContent='Excelente'; scoreAction.style.cssText='background:#E8F5EE;border-color:#1D9E75;color:#1C6B47'; scoreAction.textContent='Pode subir para validação'; }
  else if (pct >= 75) { heroScore.style.color='#185FA5'; scoreLabel.style.cssText='background:#EBF3FB;color:#185FA5'; scoreLabel.textContent='Bom'; scoreAction.style.cssText='background:#EBF3FB;border-color:#378ADD;color:#185FA5'; scoreAction.textContent='Ajustes finos — pode ir para validação'; }
  else if (pct >= 60) { heroScore.style.color='#8A6300'; scoreLabel.style.cssText='background:#FFF8E6;color:#8A6300'; scoreLabel.textContent='Médio'; scoreAction.style.cssText='background:#FFF8E6;border-color:#EF9F27;color:#8A6300'; scoreAction.textContent='Revisar e corrigir pontos críticos'; }
  else { heroScore.style.color='#B52B2B'; scoreLabel.style.cssText='background:#FDEAEA;color:#B52B2B'; scoreLabel.textContent='Crítico'; scoreAction.style.cssText='background:#FDEAEA;border-color:#E24B4A;color:#B52B2B'; scoreAction.textContent='Ajusta antes de subir — ver itens abaixo'; }
  const cutAlert = document.getElementById('cutAlert');
  if (result.cut_rules_triggered?.length) { cutAlert.classList.add('visible'); document.getElementById('cutItems').innerHTML = result.cut_rules_triggered.map(r => `<div class="cut-item"><div class="cut-dot"></div>${r}</div>`).join(''); }
  const blocksGrid = document.getElementById('blocksGrid'); blocksGrid.innerHTML = '';
  const blockBars = document.getElementById('blockBars'); blockBars.innerHTML = '';
  CRITERIA.forEach(block => {
    const bs = result.scores[block.id]||{};
    let bp = 0; block.criteria.forEach(c => { bp += (bs[c.id]||0); });
    const bpct = Math.round((bp/block.maxPts)*100);
    let pc, pb;
    if (bpct>=90){pc='#1C6B47';pb='#E8F5EE';}else if(bpct>=75){pc='#185FA5';pb='#EBF3FB';}else if(bpct>=60){pc='#8A6300';pb='#FFF8E6';}else{pc='#B52B2B';pb='#FDEAEA';}
    const card = document.createElement('div'); card.className='block-card';
    card.innerHTML = `<div class="block-header"><div class="block-title">${block.title}</div><div class="block-score" style="color:${pc}">${bpct}%</div></div>${block.criteria.map(c=>{const s=bs[c.id]??0;return`<div class="criterion-row"><div class="criterion-name">${c.name}</div><div class="score-pills"><div class="score-pill pill-0${s===0?' active':''}">0</div><div class="score-pill pill-1${s===1?' active':''}">1</div><div class="score-pill pill-2${s===2?' active':''}">2</div></div></div>`;}).join('')}<div class="block-footer"><div class="block-total-label">Score Final</div><div style="display:flex;align-items:center;gap:8px"><span class="block-pct" style="background:${pb};color:${pc}">${bpct}%</span><span style="font-size:13px;font-weight:600;font-family:var(--mono);color:${pc}">${bp} de ${block.maxPts}</span></div></div>`;
    blocksGrid.appendChild(card);
    const barColor = bpct>=75?'#1D9E75':bpct>=60?'#EF9F27':'#E24B4A';
    blockBars.innerHTML += `<div style="margin-bottom:8px"><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text3)"><span>${block.title}</span><span style="font-family:var(--mono)">${bp}/${block.maxPts}</span></div><div class="bar-track"><div class="bar-fill" style="width:${bpct}%;background:${barColor}"></div></div></div>`;
  });
  const feedbackItems = document.getElementById('feedbackItems'); feedbackItems.innerHTML='';
  (result.feedback||[]).forEach(f => { const d=document.createElement('div'); d.className=`feedback-item ${f.level}`; d.innerHTML=`<span class="feedback-tag">${f.block.toUpperCase()}</span>${f.text}`; feedbackItems.appendChild(d); });
  setTimeout(() => { document.querySelectorAll('.bar-fill').forEach(b => { const w=b.style.width; b.style.width='0'; requestAnimationFrame(()=>{b.style.width=w;}); }); }, 100);
}
</script>
</body>
</html>
